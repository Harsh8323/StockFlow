PORT=5000
NODE_ENV=development

# MongoDB connection string (Atlas or local)
MONGO_URI=mongodb://127.0.0.1:27017/stockflow

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS — origin allowed to call the API.
# Single value, comma-separated list, or '*' for local-only convenience.
#   CLIENT_ORIGIN=http://localhost:5173
#   CLIENT_ORIGIN=https://stockflow.vercel.app,https://staging.stockflow.dev
CLIENT_ORIGIN=http://localhost:5173

# Rate limiting (auth routes)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# ---------------------------------------------------------------------------
# Image storage (optional)
#
# Leave the three CLOUDINARY_* values blank to fall back to local-disk storage
# in server/uploads/ (fine for dev, but Render's filesystem is ephemeral).
#
# To use Cloudinary in production:
#   1. Create a free account at https://cloudinary.com/
#   2. Copy values from Dashboard -> "Product Environment Credentials"
#   3. Set all three vars below
#
# When all three are present the server boots in "cloudinary" storage mode
# and stores secure CDN URLs + public_ids on each product.
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=stockflow/products

# ---------------------------------------------------------------------------
# Organization branding — shown on generated invoice PDFs.
# All optional; sensible defaults are used if unset.
# ---------------------------------------------------------------------------
ORG_NAME=StockFlow
ORG_TAGLINE=Order & Inventory Management
ORG_EMAIL=
ORG_PHONE=
ORG_ADDRESS=
